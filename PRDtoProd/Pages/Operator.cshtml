@page "/operator"
@model PRDtoProd.Pages.OperatorModel
@{
    ViewData["Title"] = "Decision Evidence";
    ViewData["NavTitle"] = "DECISION EVIDENCE";
}

@section Styles {
<style>
    /* Specific Operator Page Styles */
    .boundary-panel {
        background: var(--color-bg-inset);
        border: 2px solid var(--color-danger);
        padding: var(--sp-xl);
        margin-bottom: var(--sp-2xl);
    }
    .boundary-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--sp-xl);
    }
    @@media (min-width: 900px) {
        .boundary-grid {
            grid-template-columns: 1.5fr 1fr;
        }
    }
    .boundary-rule {
        color: var(--color-danger);
        font-family: var(--sans);
        font-size: var(--fs-xl);
        font-weight: 800;
        line-height: 1.1;
        letter-spacing: -0.02em;
        margin-bottom: var(--sp-md);
    }
    .boundary-copy {
        color: var(--color-text-primary);
        font-size: var(--fs-base);
        line-height: 1.6;
    }
    .boundary-kv {
        border-top: 1px solid var(--color-danger-border);
        padding-top: var(--sp-sm);
        margin-top: var(--sp-sm);
    }
    .boundary-kv:first-child {
        border-top: none;
        padding-top: 0;
        margin-top: 0;
    }

    .empty-state {
        color: var(--color-text-tertiary);
        font-family: var(--mono);
        font-size: var(--fs-sm);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        padding: var(--sp-md) 0;
    }

    /* Drill Runs Grid overlay */
    .run-grid {
        display: grid;
        gap: 1px;
        background: var(--color-border);
        border: 1px solid var(--color-border);
    }
    .run-row {
        background: var(--color-bg-base);
        padding: var(--sp-md) var(--sp-lg);
        display: flex;
        flex-direction: column;
        gap: var(--sp-sm);
    }
    @@media(min-width: 768px){
        .run-row {
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
        }
    }
    .stage-dots {
        display: flex;
        gap: 4px;
        align-items: center;
    }
    .stage-dot {
        width: 12px;
        height: 12px;
        border-radius: 0; /* Brutalist sharp */
    }
    .stage-dot-pass { background: var(--color-success); border: 1px solid var(--color-success-border); }
    .stage-dot-manual { background: var(--color-warning); border: 1px solid var(--color-warning-border); }
    .stage-dot-fail { background: var(--color-danger); border: 1px solid var(--color-danger-border); }
    .stage-dot-skip { background: var(--color-bg-base); border: 1px solid var(--color-border-heavy); }
</style>
}

<div>
    <div style="margin-bottom: var(--sp-2xl);">
        <div class="section-label">// oversight layer — visible decisions, not hidden automation</div>
        <h1>Decision Evidence</h1>
        <p class="text-dim" style="max-width: 800px; margin-top: var(--sp-md); font-size: var(--fs-lg);">
            Evidence-backed view of published pipeline decision artifacts. Shows
            what the system did autonomously, what it blocked, and what it handed
            back to a human. Built from real decision events, not live state.
        </p>
    </div>

    <section aria-label="Operator metrics" class="data-grid" style="grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); margin-bottom: var(--sp-2xl);">
        <div class="data-cell data-cell-green">
            <div class="metric-val metric-val-green">@Model.Metrics.AutonomousActed</div>
            <div class="metric-lbl text-green">autonomous acted</div>
        </div>
        <div class="data-cell data-cell-red">
            <div class="metric-val metric-val-red">@Model.Metrics.Blocked</div>
            <div class="metric-lbl text-red">blocked</div>
        </div>
        <div class="data-cell data-cell-amber">
            <div class="metric-val metric-val-amber">@Model.Metrics.QueuedForHuman</div>
            <div class="metric-lbl text-amber">queued for human</div>
        </div>
        <div class="data-cell">
            <div class="metric-val">@Model.Metrics.Escalated</div>
            <div class="metric-lbl">escalated</div>
        </div>
    </section>

    <section class="boundary-panel" aria-labelledby="boundary-heading">
        <div class="flex-row justify-between" style="margin-bottom: var(--sp-xl); flex-wrap: wrap; gap: var(--sp-md);">
            <div>
                <div class="section-label">// hard boundary</div>
                <h2 id="boundary-heading" style="color: var(--color-danger);">The system stops before it can widen its own authority.</h2>
            </div>
            <span class="badge badge-red">human-owned safety rules</span>
        </div>

        @if (Model.FeaturedBoundaryStop is null)
        {
            <div class="empty-state">No safety-boundary stop has been recorded yet.</div>
        }
        else
        {
            <div class="boundary-grid">
                <div>
                    <div class="boundary-rule">
                        @Model.FeaturedBoundaryStop.Summary
                    </div>
                    <div class="boundary-copy">
                        This is the explicit stop condition for the demo. The AI can implement,
                        review, merge, and repair inside policy, but it cannot change workflow
                        rules, secrets, merge scope, or other safety-critical surfaces without a
                        human taking over.
                    </div>
                    <div class="flex-row" style="margin-top: var(--sp-lg); flex-wrap: wrap; gap: var(--sp-xs);">
                        <span class="badge badge-red">@Model.FeaturedBoundaryStop.Outcome</span>
                        <span class="code-pill">@Model.FeaturedBoundaryStop.RequestedAction</span>
                        @foreach (var evidence in Model.FeaturedBoundaryStop.Evidence)
                        {
                            <span class="code-pill">@evidence</span>
                        }
                    </div>
                </div>
                <div>
                    <div class="boundary-kv">
                        <div class="metric-lbl">target</div>
                        <div class="log-record-title">@(Model.FeaturedBoundaryStop.Target.Display ?? Model.FeaturedBoundaryStop.Target.Path ?? Model.FeaturedBoundaryStop.Target.Type)</div>
                    </div>
                    <div class="boundary-kv">
                        <div class="metric-lbl">policy reason</div>
                        <div class="log-record-title">@(Model.FeaturedBoundaryStop.PolicyResult.Reason ?? "human review required")</div>
                    </div>
                    <div class="boundary-kv">
                        <div class="metric-lbl">human owner</div>
                        <div class="log-record-title">@(Model.FeaturedBoundaryStop.HumanOwner ?? "unassigned")</div>
                    </div>
                    <div class="boundary-kv">
                        <div class="metric-lbl">source workflow</div>
                        <div class="log-record-title">@Model.FeaturedBoundaryStop.Workflow</div>
                    </div>
                </div>
            </div>
        }
    </section>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: var(--sp-2xl); margin-bottom: var(--sp-3xl);">
        <section aria-labelledby="blocked-heading">
            <div class="section-header">
                <div>
                    <div class="section-label">// blocked actions</div>
                    <h2 id="blocked-heading">Human-Required Refusals</h2>
                </div>
                <span class="badge badge-red">@Model.Queue.Blocked.Count BLOCKED</span>
            </div>
            
            @if (Model.Queue.Blocked.Count == 0)
            {
                <div class="empty-state">No blocked actions recorded.</div>
            }
            else
            {
                @foreach (var decision in Model.Queue.Blocked)
                {
                    <article class="log-record" style="grid-template-columns: 1fr;">
                        <div class="flex-row" style="gap: var(--sp-xs); margin-bottom: var(--sp-xs);">
                            <span class="badge badge-red">@decision.Outcome</span>
                            <span class="code-pill">@decision.RequestedAction</span>
                        </div>
                        <div class="log-record-title">@decision.Summary</div>
                        <div class="log-record-meta" style="margin-top: var(--sp-xs);">
                            <div>target: @(decision.Target.Display ?? decision.Target.Path ?? decision.Target.Type)</div>
                            <div>reason: @(decision.PolicyResult.Reason ?? "human review required")</div>
                            <div style="margin-top: var(--sp-xs);">
                                @foreach (var evidence in decision.Evidence)
                                {
                                    <span class="code-pill" style="font-size: 0.6rem; padding: 1px 4px; margin-right: 2px;">@evidence</span>
                                }
                            </div>
                        </div>
                    </article>
                }
            }
        </section>

        <section aria-labelledby="queued-heading">
            <div class="section-header">
                <div>
                    <div class="section-label">// human queue</div>
                    <h2 id="queued-heading">Waiting on Operator</h2>
                </div>
                <span class="badge badge-amber">@Model.Queue.QueuedForHuman.Count QUEUED</span>
            </div>
            
            @if (Model.Queue.QueuedForHuman.Count == 0)
            {
                <div class="empty-state">No queued actions recorded.</div>
            }
            else
            {
                @foreach (var decision in Model.Queue.QueuedForHuman)
                {
                    <article class="log-record" style="grid-template-columns: 1fr;">
                        <div class="flex-row" style="gap: var(--sp-xs); margin-bottom: var(--sp-xs);">
                            <span class="badge badge-amber">@decision.Outcome</span>
                            <span class="code-pill">@decision.RequestedAction</span>
                        </div>
                        <div class="log-record-title">@decision.Summary</div>
                        <div class="log-record-meta" style="margin-top: var(--sp-xs);">
                            <div>target: @(decision.Target.Display ?? decision.Target.Path ?? decision.Target.Type)</div>
                            <div>reason: @(decision.PolicyResult.Reason ?? "human review required")</div>
                        </div>
                    </article>
                }
            }
        </section>
    </div>

    @if (Model.EscalatedDecisions.Count > 0)
    {
        <section aria-labelledby="escalated-heading" style="margin-bottom: var(--sp-3xl);">
            <div class="section-header" style="border-bottom-color: var(--color-warning);">
                <div>
                    <div class="section-label text-amber">// escalated decisions</div>
                    <h2 id="escalated-heading" style="color: var(--color-warning);">Escalated Beyond Routing</h2>
                </div>
                <span class="badge badge-amber">@Model.EscalatedDecisions.Count escalated</span>
            </div>
            <div style="display: grid; grid-template-columns: 1fr; gap: 0;">
                @foreach (var decision in Model.EscalatedDecisions)
                {
                    <article class="log-record">
                        <div class="flex-row" style="gap: var(--sp-xs);">
                            <span class="badge badge-amber">escalated</span>
                            <span class="code-pill">@decision.RequestedAction</span>
                        </div>
                        <div class="log-record-title">@decision.Summary</div>
                        <div class="log-record-meta text-right">
                            @(decision.PolicyResult.Reason ?? "escalation required")
                        </div>
                    </article>
                }
            </div>
        </section>
    }

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: var(--sp-2xl); margin-bottom: var(--sp-3xl);">
        <section aria-labelledby="autonomous-heading">
            <details open>
                <summary class="section-header" style="cursor: pointer; list-style: none;">
                    <div>
                        <div class="section-label">// autonomous lane</div>
                        <h2 id="autonomous-heading">Recent Autonomous</h2>
                    </div>
                    <span class="badge badge-green">@Model.Queue.RecentAutonomous.Count ACTED</span>
                </summary>
                @if (Model.Queue.RecentAutonomous.Count == 0)
                {
                    <div class="empty-state">No autonomous actions recorded.</div>
                }
                else
                {
                    <div style="display: grid; grid-template-columns: 1fr; gap: 0;">
                        @foreach (var decision in Model.Queue.RecentAutonomous)
                        {
                            <article class="log-record" style="grid-template-columns: 1fr;">
                                <div class="flex-row" style="gap: var(--sp-xs); margin-bottom: var(--sp-xs);">
                                    <span class="badge badge-green">@decision.Outcome</span>
                                    <span class="code-pill">@decision.RequestedAction</span>
                                </div>
                                <div class="log-record-title">@decision.Summary</div>
                                <div class="log-record-meta" style="margin-top: var(--sp-xs);">
                                    @decision.Workflow — @(decision.Target.Display ?? decision.Target.Path ?? decision.Target.Type)
                                </div>
                            </article>
                        }
                    </div>
                }
            </details>
        </section>

        <section aria-labelledby="ledger-heading">
            <div class="section-header">
                <div>
                    <div class="section-label">// decision ledger</div>
                    <h2 id="ledger-heading">Recent Entries</h2>
                </div>
                <span class="badge badge-blue">@Model.RecentDecisions.Count SHOWING</span>
            </div>
            <div style="display: grid; grid-template-columns: 1fr; gap: 0;">
                @foreach (var decision in Model.RecentDecisions)
                {
                    <article class="log-record" style="grid-template-columns: 1fr;">
                        <div class="flex-row justify-between" style="width: 100%; margin-bottom: var(--sp-xs);">
                            <div class="flex-row" style="gap: var(--sp-xs);">
                                <span class="badge @(decision.Outcome == "blocked" ? "badge-red" : decision.Outcome == "queued_for_human" ? "badge-amber" : "badge-green")">@decision.Outcome</span>
                                <span class="code-pill">@decision.RequestedAction</span>
                            </div>
                            <span class="log-record-meta">@decision.Timestamp</span>
                        </div>
                        <div class="log-record-title">@decision.Summary</div>
                        <div class="log-record-meta" style="margin-top: var(--sp-xs);">
                            actor: @decision.Actor.Name · target: @(decision.Target.Display ?? decision.Target.Path ?? decision.Target.Type)
                        </div>
                    </article>
                }
            </div>
        </section>
    </div>

    <section aria-labelledby="past-runs-heading">
        <div class="section-header">
            <div>
                <div class="section-label">// past runs</div>
                <h2 id="past-runs-heading">Historical Runs</h2>
            </div>
            <span class="badge badge-blue">@Model.DrillRuns.Count RUNS</span>
        </div>

        @if (Model.DrillRuns.Count == 0)
        {
            <div class="empty-state">No completed drill runs recorded.</div>
        }
        else
        {
            <div class="run-grid">
                @foreach (var run in Model.DrillRuns)
                {
                    var stageNames = new[] { "ci_failure", "issue_created", "auto_dispatch", "repair_pr", "ci_green", "auto_merge", "main_recovered" };
                    var stageSummary = OperatorModel.GetDrillStageSummary(run);
                    var totalStages = stageNames.Length;
                    var durationText = OperatorModel.GetDrillDurationText(run);
                    var verdictBadge = run.Verdict switch
                    {
                        "PASS" => "badge-green",
                        "FAIL" => "badge-red",
                        _ => "badge-amber"
                    };

                    <div class="run-row">
                        <div class="flex-col" style="gap: var(--sp-xs);">
                            <div class="flex-row" style="gap: var(--sp-md);">
                                <span class="badge @verdictBadge">@run.Verdict</span>
                                <span class="font-mono text-primary font-bold">@run.DrillId</span>
                            </div>
                            <div class="log-record-meta">
                                <span class="code-pill">@run.DrillType</span>
                                <span style="margin-left: var(--sp-md);">
                                    @stageSummary.CompletedCount/@totalStages complete 
                                    (@durationText)
                                </span>
                            </div>
                            @if (!string.IsNullOrEmpty(run.VerdictReason))
                            {
                                <div class="log-record-meta text-dim mt-1">@run.VerdictReason</div>
                            }
                        </div>

                        <div class="flex-col text-right" style="gap: var(--sp-sm);">
                            <div class="stage-dots">
                                @foreach (var name in stageNames)
                                {
                                    var dotClass = run.Stages.TryGetValue(name, out var stage)
                                        ? stage.Status switch
                                        {
                                            "pass" => "stage-dot-pass",
                                            "pass_manual" => "stage-dot-manual",
                                            _ => "stage-dot-fail"
                                        }
                                        : "stage-dot-skip";
                                    <div class="stage-dot @dotClass" title="@name"></div>
                                }
                            </div>
                            <div style="display: flex; gap: var(--sp-xs); justify-content: flex-end;">
                                @if (stageSummary.ManualCount > 0)
                                {
                                    <span class="badge badge-amber">@stageSummary.ManualCount manual</span>
                                }
                                @if (stageSummary.FailedCount > 0)
                                {
                                    <span class="badge badge-red">@stageSummary.FailedCount failed</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <div style="margin-top: var(--sp-2xl);">
            <details>
                <summary class="section-label" style="cursor: pointer; list-style: none;">
                    [+] Show evidence trail (@Model.DecisionTrail.Count entries)
                </summary>
                <div style="border-left: 2px solid var(--color-border-heavy); padding-left: var(--sp-md); margin-top: var(--sp-md); display: flex; flex-direction: column; gap: var(--sp-md);">
                    @foreach (var decision in Model.DecisionTrail)
                    {
                        <article class="log-record" style="grid-template-columns: auto 1fr; border-bottom: none; border-top: none; padding: 0;">
                            <div class="log-record-meta style: width: 140px;">@decision.Timestamp</div>
                            <div>
                                <div class="flex-row" style="gap: var(--sp-xs); margin-bottom: 4px;">
                                    <span class="badge @(decision.Outcome == "blocked" ? "badge-red" : decision.Outcome == "queued_for_human" ? "badge-amber" : "badge-green")">@decision.Outcome</span>
                                    <span class="code-pill" style="font-size: 0.6rem;">@decision.RequestedAction</span>
                                </div>
                                <div class="log-record-title" style="font-size: var(--fs-sm);">@decision.Summary</div>
                            </div>
                        </article>
                    }
                </div>
            </details>
        </div>
    </section>
</div>
