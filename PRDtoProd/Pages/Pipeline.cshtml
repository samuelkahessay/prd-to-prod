@page "/pipeline"
@model PRDtoProd.Pages.PipelineModel
@{
    ViewData["Title"] = "Pipeline";
    ViewData["NavTitle"] = "PIPELINE";
}

@section Styles {
<style>
    /* Specific Pipeline Styles */
    .warning {
        border: 2px solid var(--color-warning);
        background: var(--color-bg-base);
        color: var(--color-warning);
        padding: var(--sp-md);
        margin-bottom: var(--sp-xl);
        font-family: var(--mono);
        text-transform: uppercase;
        font-size: var(--fs-sm);
        letter-spacing: 0.05em;
    }
    .stage-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 1px;
        background: var(--color-border);
        border: 1px solid var(--color-border);
    }
    .stage-node {
        background: var(--color-bg-base);
        padding: var(--sp-lg);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
    }
    .stage-count {
        font-family: var(--sans);
        font-size: 2.5rem;
        font-weight: 800;
        line-height: 1;
        letter-spacing: -0.05em;
        color: var(--color-text-primary);
        margin-bottom: var(--sp-sm);
    }
    .status-pill {
        display: inline-block;
        font-family: var(--mono);
        font-size: var(--fs-xs);
        padding: 4px 8px;
        border: 1px solid var(--color-border-heavy);
        text-transform: uppercase;
        letter-spacing: 0.15em;
        font-weight: 800;
        transition: all 0.3s var(--ease-out-expo);
    }
    .status-pill.active {
        color: var(--color-success);
        border-color: var(--color-success-border);
        background: var(--color-bg-base);
    }
    .status-pill.idle {
        color: var(--color-text-dim);
        background: var(--color-bg-base);
    }

    /* Mode selector */
    .mode-btn {
        display: inline-flex;
        align-items: center;
        gap: var(--sp-sm);
        padding: var(--sp-sm) var(--sp-md);
        border: 1px solid var(--color-border-heavy);
        background: var(--color-bg-base);
        color: var(--color-text-dim);
        font-family: var(--mono);
        font-size: var(--fs-sm);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        cursor: pointer;
        transition: none;
    }
    .mode-btn:hover {
        border-color: var(--color-accent);
        color: var(--color-accent);
    }
    .mode-btn.active {
        border-color: var(--color-accent);
        color: var(--color-accent);
        background: var(--color-border);
    }
    .live-dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        background: var(--color-success);
    }

    /* Replay controls */
    .ctrl-btn {
        padding: var(--sp-sm) var(--sp-md);
        border: 1px solid var(--color-border-heavy);
        background: var(--color-bg-base);
        color: var(--color-text-primary);
        font-family: var(--mono);
        font-size: var(--fs-sm);
        text-transform: uppercase;
        cursor: pointer;
    }
    .ctrl-btn:hover {
        border-color: var(--color-accent);
        color: var(--color-accent);
    }
    .ctrl-btn.accent {
        color: var(--color-success);
        border-color: var(--color-success-border);
    }
    .ctrl-btn.accent:hover {
        background: var(--color-border);
    }

    /* Event log timeline */
    .event-log {
        height: 32rem;
        overflow-y: auto;
        overflow-anchor: none;
        border: 1px solid var(--color-border);
        background: var(--color-bg-base);
    }
    .event-item {
        display: grid;
        grid-template-columns: 8px 60px 120px auto;
        gap: var(--sp-md);
        align-items: center;
        padding: var(--sp-md) var(--sp-md);
        border-bottom: 1px solid var(--color-border);
        transition: all 0.4s var(--ease-out-expo);
        border-left: 4px solid transparent;
        margin-left: -4px; /* offset the border so it perfectly aligns */
    }
    .event-item.current {
        background: var(--color-bg-inset);
        border-left: 4px solid var(--color-accent);
        padding-left: var(--sp-md);
        box-shadow: inset 0 2px 8px rgba(0,0,0,0.4);
    }
    .event-item:hover {
        background: var(--color-bg-elevated);
        border-left-color: var(--color-border-heavy);
    }
    .event-item.upcoming {
        opacity: 0.3;
        filter: grayscale(1);
    }
    .event-marker {
        width: 8px;
        height: 8px;
        background: var(--color-border-heavy);
    }
    .event-marker.issue_created { background: var(--color-warning); }
    .event-marker.pr_opened { background: var(--color-accent); }
    .event-marker.review_approved, .event-marker.review_commented { background: var(--color-text-dim); }
    .event-marker.pr_merged { background: var(--color-success); }
    
    .event-time {
        font-family: var(--mono);
        font-size: var(--fs-xs);
        color: var(--color-text-dim);
    }
    .event-type {
        font-family: var(--mono);
        font-size: var(--fs-xs);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .event-type.issue_created { color: var(--color-warning); }
    .event-type.pr_opened { color: var(--color-accent); }
    .event-type.review_approved, .event-type.review_commented { color: var(--color-text-dim); }
    .event-type.pr_merged { color: var(--color-success); }

    .current-event-box {
        border: 2px solid var(--color-accent);
        background: var(--color-bg-inset);
        padding: var(--sp-2xl); /* Massive padding for impact */
        margin-bottom: var(--sp-xl);
        animation: event-reveal 0.6s var(--ease-out-expo);
    }
    
    @@keyframes event-reveal {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Run history table */
    .run-row {
        display: grid;
        grid-template-columns: 60px 2fr 1.5fr 80px 80px 100px;
        gap: var(--sp-md);
        align-items: center;
        padding: var(--sp-md) var(--sp-lg);
        border-bottom: 1px solid var(--color-border);
        cursor: pointer;
    }
    .run-row:hover {
        background: var(--color-border);
    }
    .run-row-header {
        font-family: var(--mono);
        color: var(--color-text-tertiary);
        font-size: var(--fs-xs);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        cursor: default;
        border-bottom: 2px solid var(--color-border-heavy);
    }
    .run-row-header:hover {
        background: transparent;
    }
    .run-num {
        color: var(--color-accent);
        font-family: var(--mono);
    }

    /* Two-column layout */
    .pipeline-columns {
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: var(--sp-2xl);
        align-items: start;
    }
    .pipeline-right {
        position: sticky;
        top: var(--sp-2xl);
    }

    /* Activity feed */
    .feed-item {
        padding: var(--sp-md);
        border-bottom: 1px solid var(--color-border);
        border-left: 4px solid var(--color-border-heavy);
        transition: background 0.3s var(--ease-out-expo), padding-left 0.3s var(--ease-out-expo);
    }
    .feed-item:hover {
        background: var(--color-bg-elevated);
        padding-left: var(--sp-lg); /* Push item to the right subtly */
    }
    .feed-item.feed-issue { border-left-color: var(--color-warning); }
    .feed-item.feed-pr { border-left-color: var(--color-accent); }
    .feed-item.feed-run { border-left-color: var(--color-success); }
    .sidebar-feed {
        max-height: 60vh;
        overflow-y: auto;
        border: 1px solid var(--color-border);
        margin-top: 2px;
    }

    @@media (max-width: 1024px) {
        .pipeline-columns {
            grid-template-columns: 1fr;
        }
        .pipeline-right {
            position: static;
        }
    }
    @@media (max-width: 768px) {
        .run-row {
            grid-template-columns: 50px 1fr 80px 80px;
        }
        .run-row > :nth-child(3), .run-row > :nth-child(6) {
            display: none;
        }
        .event-item {
            grid-template-columns: 8px 60px 1fr;
        }
        .event-item > .event-type {
            display: none;
        }
    }
    .hidden {
        display: none !important;
    }
</style>
}

<div>
    <div style="margin-bottom: var(--sp-2xl);">
        <div class="section-label">// pipeline state &mdash; live &amp; historical</div>
        <h1>Pipeline</h1>
        <p class="text-dim" style="max-width: 800px; margin-top: var(--sp-md); font-size: var(--fs-lg);">
            Live GitHub pipeline state and historical run playback. Switch between real-time state
            and step-through replays of completed pipeline runs. Use <kbd style="font-family: var(--mono); border: 1px solid var(--color-border); padding: 0 4px;">&larr;</kbd> <kbd style="font-family: var(--mono); border: 1px solid var(--color-border); padding: 0 4px;">&rarr;</kbd> arrow keys in replay mode.
        </p>
        <p style="font-family: var(--mono); color: var(--color-text-dim); border-left: 2px solid var(--color-border-heavy); padding-left: var(--sp-sm); margin-top: var(--sp-sm); font-size: var(--fs-sm);">
            Live GitHub pipeline state. Runs are real — this repo builds itself.
        </p>
    </div>

    <!-- Mode Selector -->
    <div id="modeSelector" class="flex-row" style="flex-wrap: wrap; margin-bottom: var(--sp-xl);" role="tablist">
        <button class="mode-btn active" data-mode="live" onclick="switchMode('live')" role="tab" aria-selected="true">
            <span class="live-dot"></span> LIVE
        </button>
    </div>

    <!-- Warning Box (live mode) -->
    <div id="warningBox" class="warning hidden" role="alert"></div>

    <!-- Replay Controls (replay mode) -->
    <div id="replayControls" style="border: 1px solid var(--color-border); padding: var(--sp-lg); margin-bottom: var(--sp-xl);" class="hidden">
        <div class="flex-row justify-between" style="flex-wrap: wrap; gap: var(--sp-md);">
            <div>
                <div class="flex-row" style="gap: var(--sp-sm); margin-bottom: var(--sp-xs);">
                    <span class="badge badge-amber">REPLAY</span>
                    <div class="section-label">verified pipeline run</div>
                </div>
                <div id="replayRunName" style="font-family: var(--sans); font-size: var(--fs-xl); font-weight: 800;"></div>
            </div>
            <div class="flex-row" style="gap: var(--sp-sm);">
                <span id="replayStepLabel" class="metric-lbl" style="margin-right: var(--sp-md);">step 0 / 0</span>
                <button class="ctrl-btn" onclick="prevStep()" title="Previous step (←)">&#9664;</button>
                <button class="ctrl-btn" onclick="nextStep()" title="Next step (→)">&#9654;</button>
                <button class="ctrl-btn" onclick="resetReplay()" title="Reset to start">&#8634;</button>
                <button class="ctrl-btn accent" onclick="switchMode('live')">&#9679; LIVE</button>
            </div>
        </div>
        <div id="replayStats" class="flex-row" style="flex-wrap: wrap; gap: var(--sp-lg); margin-top: var(--sp-md); font-family: var(--mono); font-size: var(--fs-sm); color: var(--color-text-dim);"></div>
    </div>

    <!-- Metrics (compact bar) -->
    <div id="metricsRow" class="data-grid" style="grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); margin-bottom: var(--sp-2xl);" aria-label="Pipeline metrics">
        <div class="data-cell">
            <div id="metricVal0" class="metric-val" aria-live="polite">0</div>
            <div id="metricLbl0" class="metric-lbl">actionable issues</div>
        </div>
        <div class="data-cell data-cell-accent">
            <div id="metricVal1" class="metric-val text-accent" aria-live="polite">0</div>
            <div id="metricLbl1" class="metric-lbl text-accent">open prs</div>
        </div>
        <div class="data-cell data-cell-green">
            <div id="metricVal2" class="metric-val metric-val-green" aria-live="polite">0</div>
            <div id="metricLbl2" class="metric-lbl text-green">active runs</div>
        </div>
        <div class="data-cell data-cell-amber">
            <div id="metricVal3" class="metric-val metric-val-amber" aria-live="polite">0</div>
            <div id="metricLbl3" class="metric-lbl text-amber">deferred <span style="opacity:0.5">(rate-limited)</span></div>
        </div>
        <div class="data-cell data-cell-red">
            <div id="metricVal4" class="metric-val metric-val-red" aria-live="polite">0</div>
            <div id="metricLbl4" class="metric-lbl text-red">repairs <span style="opacity:0.5">(self-heals)</span></div>
        </div>
        <div class="data-cell">
            <div id="metricVal5" class="metric-val" aria-live="polite">0</div>
            <div id="metricLbl5" class="metric-lbl">merge armed</div>
        </div>
        <div class="data-cell">
            <div id="metricVal6" style="font-family: var(--mono); font-size: var(--fs-md); letter-spacing: -0.02em; padding-top: 8px;">loading</div>
            <div id="metricLbl6" class="metric-lbl">mode</div>
        </div>
    </div>

    <!-- Two-Column Layout -->
    <div class="pipeline-columns">
        <!-- Left Column -->
        <div class="pipeline-left">
            <!-- Stage Grid -->
            <section aria-labelledby="stage-heading" style="margin-bottom: var(--sp-3xl);">
                <div class="section-header">
                    <div>
                        <div class="section-label">// stage map</div>
                        <h2 id="stage-heading">Current pipeline flow</h2>
                    </div>
                    <div id="updatedAt" class="metric-lbl">updated: pending</div>
                </div>
                <div id="stageGrid" class="stage-grid" aria-live="polite"></div>
            </section>

            <!-- Live Content (left side) -->
            <div id="liveContent">
                <section aria-labelledby="issue-heading" style="margin-bottom: var(--sp-2xl);">
                    <div class="section-header">
                        <div>
                            <div class="section-label">// open actionable pipeline issues</div>
                            <h2 id="issue-heading">Issue queue</h2>
                        </div>
                    </div>
                    <div id="issueList" style="display: grid; grid-template-columns: 1fr; gap: 0;" aria-live="polite">Loading issues...</div>
                </section>

                <section aria-labelledby="pr-heading" style="margin-bottom: var(--sp-2xl);">
                    <div class="section-header">
                        <div>
                            <div class="section-label">// open pipeline prs</div>
                            <h2 id="pr-heading">Pull requests</h2>
                        </div>
                    </div>
                    <div id="prList" style="display: grid; grid-template-columns: 1fr; gap: 0;" aria-live="polite">Loading pull requests...</div>
                </section>

                <section aria-labelledby="run-heading">
                    <div class="section-header">
                        <div>
                            <div class="section-label">// actions in progress</div>
                            <h2 id="run-heading">Workflow runs</h2>
                        </div>
                    </div>
                    <div id="runList" style="display: grid; grid-template-columns: 1fr; gap: 0;" aria-live="polite">Loading workflow runs...</div>
                </section>
            </div>

            <!-- Replay Content (left side — current event highlight) -->
            <div id="replayContent" class="hidden">
                <div id="currentEventBox" class="current-event-box hidden">
                    <div class="flex-row" style="gap: var(--sp-md); margin-bottom: var(--sp-sm);">
                        <span id="currentEventMarker" class="event-marker"></span>
                        <span id="currentEventType" class="event-type"></span>
                        <span id="currentEventItem" style="font-family: var(--mono); font-size: var(--fs-sm); color: var(--color-accent);"></span>
                    </div>
                    <div id="currentEventTitle" style="font-family: var(--sans); font-size: var(--fs-lg); font-weight: 700;"></div>
                    <div id="currentEventTime" style="font-family: var(--mono); font-size: var(--fs-xs); color: var(--color-text-dim); margin-top: var(--sp-sm);"></div>
                </div>
            </div>
        </div>

        <!-- Right Column (Sidebar) -->
        <div class="pipeline-right">
            <!-- Live Sidebar: Activity Feed -->
            <div id="liveSidebar">
                <section>
                    <div class="section-header" style="border-bottom-color: var(--color-accent);">
                        <div>
                            <div class="section-label">// activity</div>
                            <h2>Live feed</h2>
                        </div>
                    </div>
                    <div id="liveFeed" class="sidebar-feed">Loading...</div>
                </section>
            </div>

            <!-- Replay Sidebar: Event Timeline -->
            <div id="replaySidebar" class="hidden">
                <section>
                    <div class="section-header">
                        <div>
                            <div class="section-label">// event timeline</div>
                            <h2>Pipeline activity</h2>
                        </div>
                    </div>
                    <div id="eventLog" class="event-log"></div>
                </section>
            </div>
        </div>
    </div>

    <!-- Run History Table -->
    <section aria-labelledby="history-heading" style="margin-top: var(--sp-3xl);">
        <div class="section-header">
            <div>
                <div class="section-label">// completed pipeline runs</div>
                <h2 id="history-heading">Run history</h2>
            </div>
        </div>
        <div id="runHistory" style="border: 1px solid var(--color-border);">Loading runs...</div>
    </section>
</div>

@section Scripts {
<script>
    // ── Constants ──
    const stageChipClass = {
        queue: 'chip chip-queue',
        implementation: 'chip chip-implementation',
        review: 'chip chip-review',
        deploy: 'chip chip-deploy',
        operations: 'chip chip-ops'
    };
    const eventLabels = {
        issue_created: 'issue created',
        pr_opened: 'pr opened',
        review_approved: 'review approved',
        review_commented: 'review comment',
        pr_merged: 'pr merged'
    };
    const GITHUB_REPO = 'https://github.com/samuelkahessay/prd-to-prod';

    // ── State ──
    let currentMode = 'live';
    let liveInterval = null;
    let showcaseRuns = [];
    let replayData = null;
    let replayStep = -1;

    // ── Live Mode: Rendering ──

    async function loadSnapshot() {
        const response = await fetch('/api/pipeline/live', { cache: 'no-store' });
        if (!response.ok) throw new Error(`pipeline snapshot request failed: ${response.status}`);
        return response.json();
    }

    function renderStages(stages) {
        const grid = document.getElementById('stageGrid');
        grid.innerHTML = stages.map(stage => `
            <div class="stage-node">
                <div class="metric-lbl">${escapeHtml(stage.label)}</div>
                <div class="stage-count">${stage.count}</div>
                <span class="status-pill ${stage.status === 'active' ? 'active' : 'idle'}">${escapeHtml(stage.status)}</span>
            </div>
        `).join('');
    }

    function issueStageChip(issue) {
        const repairStages = ['repair_requested', 'incident_open'];
        const deferredStages = ['dispatch_deferred'];
        if (repairStages.includes(issue.stage))
            return `<span class="badge badge-red">${escapeHtml(issue.stageLabel)}</span>`;
        if (deferredStages.includes(issue.stage))
            return `<span class="badge badge-amber">${escapeHtml(issue.stageLabel)}</span>`;
        return `<span class="badge badge-blue">${escapeHtml(issue.stageLabel)}</span>`;
    }

    function renderIssues(issues) {
        const list = document.getElementById('issueList');
        if (!issues.length) {
            list.innerHTML = '<div class="empty-state">No active actionable pipeline issues.</div>';
            return;
        }
        list.innerHTML = issues.map(issue => `
            <div class="log-record" style="grid-template-columns: 1fr;">
                <div class="flex-row justify-between" style="width: 100%; margin-bottom: var(--sp-xs);">
                    <a class="code-pill" href="${issue.url}" target="_blank" rel="noopener noreferrer">#${issue.number}</a>
                    ${issueStageChip(issue)}
                </div>
                <div class="log-record-title">${escapeHtml(issue.title)}</div>
                <div class="log-record-meta" style="margin-top: var(--sp-xs);">labels: ${escapeHtml(issue.labels.join(', '))}</div>
                ${issue.linkedPullRequestUrl ? `<div class="log-record-meta">linked pr: <a style="color: var(--color-accent); text-decoration: underline;" href="${issue.linkedPullRequestUrl}" target="_blank" rel="noopener noreferrer">#${issue.linkedPullRequestNumber}</a></div>` : ''}
            </div>
        `).join('');
    }

    function mergeGateReason(pr) {
        if (pr.autoMergeEnabled && pr.ciState === 'passed' && pr.reviewState === 'APPROVED')
            return { text: 'Merge armed — CI passing, review approved, auto-merge enabled', cls: 'text-green' };
        if (pr.ciState === 'failed')
            return { text: 'Merge blocked — CI is failing', cls: 'text-red' };
        if (pr.reviewState === 'CHANGES_REQUESTED')
            return { text: 'Merge blocked — changes requested by reviewer', cls: 'text-red' };
        if (pr.ciState === 'running')
            return { text: 'Merge waiting — CI running', cls: 'text-amber' };
        if (pr.ciState === 'pending')
            return { text: 'Merge waiting — CI pending', cls: 'text-amber' };
        if (pr.reviewState === 'APPROVED' && !pr.autoMergeEnabled)
            return { text: 'Merge waiting — approved but auto-merge not enabled', cls: 'text-amber' };
        return { text: 'Merge waiting — review pending', cls: 'text-dim' };
    }

    function renderPullRequests(prs) {
        const list = document.getElementById('prList');
        if (!prs.length) {
            list.innerHTML = '<div class="empty-state">No open pipeline pull requests.</div>';
            return;
        }
        list.innerHTML = prs.map(pr => {
            const gate = mergeGateReason(pr);
            return `
            <div class="log-record" style="grid-template-columns: 1fr;">
                <div class="flex-row justify-between" style="width: 100%; margin-bottom: var(--sp-xs);">
                    <a class="code-pill" href="${pr.url}" target="_blank" rel="noopener noreferrer">#${pr.number}</a>
                    <span class="badge badge-blue">${escapeHtml(pr.stageLabel)}</span>
                </div>
                <div class="log-record-title">${escapeHtml(pr.title)}</div>
                <div class="${gate.cls}" style="font-family: var(--sans); font-size: var(--fs-xs); margin-top: var(--sp-xs);">${gate.text}</div>
                <div class="log-record-meta" style="margin-top: var(--sp-xs);">ci: ${escapeHtml(pr.ciState)} · review: ${escapeHtml(pr.reviewState)} · branch: ${escapeHtml(pr.headBranch)}</div>
                ${pr.linkedIssueNumber ? `<div class="log-record-meta">linked issue: #${pr.linkedIssueNumber}</div>` : ''}
            </div>`;
        }).join('');
    }

    function renderRuns(runs) {
        const list = document.getElementById('runList');
        if (!runs.length) {
            list.innerHTML = '<div class="empty-state">No workflow runs in progress.</div>';
            return;
        }
        list.innerHTML = runs.map(run => `
            <div class="log-record" style="grid-template-columns: 1fr;">
                <div class="flex-row justify-between" style="width: 100%; margin-bottom: var(--sp-xs);">
                    <a class="code-pill" href="${run.url}" target="_blank" rel="noopener noreferrer" style="font-family: var(--sans);">${escapeHtml(run.name)}</a>
                    <span class="badge ${run.stage === 'queue' ? 'badge-amber' : 'badge-blue'}">${escapeHtml(run.stageLabel)}</span>
                </div>
                <div class="log-record-meta" style="margin-top: var(--sp-xs);">event: ${escapeHtml(run.event)} · branch: ${escapeHtml(run.headBranch || 'n/a')} · actor: ${escapeHtml(run.triggeringActor || 'n/a')}</div>
            </div>
        `).join('');
    }

    function renderWarnings(warnings, mode) {
        const box = document.getElementById('warningBox');
        const messages = [];
        if (mode === 'unauthenticated') {
            messages.push('GitHub access is unauthenticated. Live polling works for a demo, but rate limits are much lower.');
        }
        messages.push(...warnings);
        if (!messages.length) {
            box.classList.add('hidden');
            box.innerHTML = '';
            return;
        }
        box.classList.remove('hidden');
        box.innerHTML = messages.map(message => `<div>${escapeHtml(message)}</div>`).join('');
    }

    function renderLiveSnapshot(snapshot) {
        setMetric(0, 'actionable issues', snapshot.summary.openIssues);
        setMetric(1, 'open prs', snapshot.summary.openPullRequests);
        setMetric(2, 'active runs', snapshot.summary.activeRuns);
        setMetric(3, 'deferred', snapshot.summary.deferredIssues);
        setMetric(4, 'repairs', snapshot.summary.repairLoops);
        setMetric(5, 'merge armed', snapshot.summary.autoMergeArmed);
        setMetric(6, 'mode', snapshot.mode, true);
        document.getElementById('updatedAt').textContent = `updated: ${snapshot.updatedAtUtc}`;

        renderWarnings(snapshot.warnings, snapshot.mode);
        renderStages(snapshot.stages);
        renderIssues(snapshot.issues);
        renderPullRequests(snapshot.pullRequests);
        renderRuns(snapshot.activeRuns);
        renderLiveFeed(snapshot);
    }

    function renderLiveFeed(snapshot) {
        const feed = document.getElementById('liveFeed');
        const items = [];

        (snapshot.issues || []).forEach(issue => {
            items.push({ type: 'issue', number: issue.number, title: issue.title, url: issue.url, label: issue.stageLabel });
        });
        (snapshot.pullRequests || []).forEach(pr => {
            const gate = mergeGateReason(pr);
            items.push({ type: 'pr', number: pr.number, title: pr.title, url: pr.url, label: pr.stageLabel, gate });
        });
        (snapshot.activeRuns || []).forEach(run => {
            items.push({ type: 'run', name: run.name, url: run.url, label: run.stageLabel });
        });

        if (!items.length) {
            feed.innerHTML = '<div class="empty-state">No active items.</div>';
            return;
        }

        feed.innerHTML = items.map(item => {
            const borderCls = item.type === 'issue' ? 'feed-issue' : item.type === 'pr' ? 'feed-pr' : 'feed-run';
            const id = item.type === 'run'
                ? `<a href="${item.url}" target="_blank" rel="noopener noreferrer" class="code-pill" style="font-family: var(--sans);">${escapeHtml(item.name)}</a>`
                : `<a href="${item.url}" target="_blank" rel="noopener noreferrer" class="code-pill">#${item.number}</a>`;
            const title = item.title ? `<div class="log-record-title" style="margin-top: var(--sp-xs); font-size: var(--fs-sm); font-weight: 500;">${escapeHtml(item.title)}</div>` : '';
            const gateInfo = item.gate ? `<div class="${item.gate.cls}" style="font-size:0.65rem;margin-top:2px">${item.gate.text}</div>` : '';
            return `<div class="feed-item ${borderCls}">
                <div class="flex-row justify-between" style="width: 100%;">
                    ${id}
                    <span style="font-family: var(--mono); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-dim);">${escapeHtml(item.type)}</span>
                </div>
                ${title}${gateInfo}
            </div>`;
        }).join('');
    }

    function setMetric(index, label, value, isText) {
        document.getElementById('metricLbl' + index).textContent = label;
        const el = document.getElementById('metricVal' + index);
        el.textContent = value;
        el.className = isText ? 'text-white text-sm truncate' : 'metric-val';
    }

    // ── Live Mode: Polling ──

    async function refreshLive() {
        try {
            const snapshot = await loadSnapshot();
            renderLiveSnapshot(snapshot);
        } catch (error) {
            renderWarnings([error.message || 'Failed to load live pipeline snapshot.'], 'unauthenticated');
        }
    }

    function startLivePolling() {
        refreshLive();
        liveInterval = window.setInterval(refreshLive, 15000);
    }

    function stopLivePolling() {
        if (liveInterval) {
            window.clearInterval(liveInterval);
            liveInterval = null;
        }
    }

    // ── Replay Mode ──

    async function loadReplayData(slug) {
        const response = await fetch('/api/showcase/' + encodeURIComponent(slug) + '/timeline', { cache: 'no-store' });
        if (!response.ok) throw new Error('Failed to load run data');
        return response.json();
    }

    function computeReplayDiffsAtStep(pullRequests, timeline, step) {
        const seenPullRequests = new Set();
        let linesAdded = 0;
        let filesChanged = 0;

        for (let i = 0; i <= step && i < timeline.length; i++) {
            const evt = timeline[i];
            if (evt.event !== 'pr_opened') continue;
            if (seenPullRequests.has(evt.item)) continue;
            seenPullRequests.add(evt.item);

            const pr = pullRequests.find(candidate => candidate.number === evt.item);
            if (!pr) continue;

            linesAdded += pr.additions || 0;
            filesChanged += pr.changed_files || 0;
        }

        return { linesAdded, filesChanged };
    }

    function computeStagesAtStep(timeline, step) {
        let issues = 0, prsOpened = 0, reviewed = 0, merged = 0;
        for (let i = 0; i <= step && i < timeline.length; i++) {
            switch (timeline[i].event) {
                case 'issue_created': issues++; break;
                case 'pr_opened': prsOpened++; break;
                case 'review_approved':
                case 'review_commented': reviewed++; break;
                case 'pr_merged': merged++; break;
            }
        }
        const queue = Math.max(0, issues - prsOpened);
        const impl = Math.max(0, prsOpened - reviewed);
        const review = Math.max(0, reviewed - merged);
        return [
            { label: 'Queue', key: 'queue', count: queue, status: queue > 0 ? 'active' : 'idle' },
            { label: 'Implementation', key: 'implementation', count: impl, status: impl > 0 ? 'active' : 'idle' },
            { label: 'Review', key: 'review', count: review, status: review > 0 ? 'active' : 'idle' },
            { label: 'Deploy', key: 'deploy', count: merged, status: merged > 0 ? 'active' : 'idle' }
        ];
    }

    function renderReplayStep() {
        if (!replayData) return;
        const timeline = replayData.timeline;
        const total = timeline.length;
        const step = replayStep;

        // Step label
        document.getElementById('replayStepLabel').textContent = `step ${step + 1} / ${total}`;

        // Stage grid
        const stages = computeStagesAtStep(timeline, step);
        renderStages(stages);

        // Replay metrics
        let issuesCreated = 0, prsOpened = 0, prsMerged = 0;
        for (let i = 0; i <= step; i++) {
            switch (timeline[i].event) {
                case 'issue_created': issuesCreated++; break;
                case 'pr_opened': prsOpened++; break;
                case 'pr_merged': prsMerged++; break;
            }
        }
        const pct = Math.round(((step + 1) / total) * 100);
        const diffs = computeReplayDiffsAtStep(replayData.pull_requests || [], timeline, step);
        setMetric(0, 'issues created', issuesCreated);
        setMetric(1, 'prs opened', prsOpened);
        setMetric(2, 'prs merged', prsMerged);
        setMetric(3, 'lines added', diffs.linesAdded.toLocaleString());
        setMetric(4, 'files changed', diffs.filesChanged);
        setMetric(5, 'completion', pct + '%');
        setMetric(6, 'tech', replayData.run.tech_stack, true);

        // Updated at
        const ts = new Date(timeline[step].timestamp);
        document.getElementById('updatedAt').textContent = `replay: ${ts.toISOString().slice(11, 19)} UTC`;

        // Current event highlight
        const evt = timeline[step];
        const box = document.getElementById('currentEventBox');
        box.classList.remove('hidden');
        document.getElementById('currentEventMarker').className = `event-marker ${evt.event}`;
        document.getElementById('currentEventType').className = `event-type ${evt.event}`;
        document.getElementById('currentEventType').textContent = eventLabels[evt.event] || evt.event;
        const prefix = evt.event.startsWith('pr_') || evt.event.startsWith('review_') ? 'PR' : 'Issue';
        document.getElementById('currentEventItem').innerHTML = `<a href="${GITHUB_REPO}/${prefix === 'PR' ? 'pull' : 'issues'}/${evt.item}" target="_blank" rel="noopener noreferrer" class="code-pill" style="color: var(--color-accent); text-decoration: none;">#${evt.item}</a>`;
        document.getElementById('currentEventTitle').textContent = cleanTitle(evt.title);
        document.getElementById('currentEventTime').textContent = ts.toISOString().replace('T', ' ').replace('Z', ' UTC');

        // Event log
        renderEventLog(timeline, step);
    }

    function renderEventLog(timeline, currentStep) {
        const log = document.getElementById('eventLog');
        log.innerHTML = timeline.map((evt, i) => {
            const cls = i === currentStep ? 'current' : (i > currentStep ? 'upcoming' : '');
            const ts = new Date(evt.timestamp);
            const time = ts.toISOString().slice(11, 16);
            const prefix = evt.event.startsWith('pr_') || evt.event.startsWith('review_') ? 'pull' : 'issues';
            return `<div class="event-item ${cls}">
                <span class="event-marker ${evt.event}"></span>
                <span class="event-time">${time}</span>
                <span class="event-type ${evt.event}">${eventLabels[evt.event] || evt.event}</span>
                <a href="${GITHUB_REPO}/${prefix}/${evt.item}" target="_blank" rel="noopener noreferrer" class="code-pill" style="font-size: var(--fs-xs);">#${evt.item}</a>
                <span style="font-family: var(--sans); font-size: var(--fs-xs); color: var(--color-text-primary); margin-left: var(--sp-sm); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${escapeHtml(cleanTitle(evt.title))}</span>
            </div>`;
        }).join('');

        // Scroll current event into view within the log container only
        const currentEl = log.querySelector('.event-item.current');
        if (currentEl) {
            const elTop = currentEl.offsetTop - log.offsetTop;
            const elBottom = elTop + currentEl.offsetHeight;
            const viewTop = log.scrollTop;
            const viewBottom = viewTop + log.clientHeight;
            if (elBottom > viewBottom) log.scrollTop = elBottom - log.clientHeight;
            else if (elTop < viewTop) log.scrollTop = elTop;
        }
    }

    function cleanTitle(title) {
        return title.replace(/^\[Pipeline\]\s*/i, '');
    }

    function nextStep() {
        if (!replayData || replayStep >= replayData.timeline.length - 1) return;
        replayStep++;
        renderReplayStep();
    }

    function prevStep() {
        if (!replayData || replayStep <= 0) return;
        replayStep--;
        renderReplayStep();
    }

    function resetReplay() {
        if (!replayData) return;
        replayStep = 0;
        renderReplayStep();
    }

    // ── Mode Switching ──

    async function switchMode(mode) {
        if (mode === currentMode) return;
        currentMode = mode;

        // Update mode selector buttons
        document.querySelectorAll('.mode-btn').forEach(btn => {
            btn.classList.toggle('active', btn.dataset.mode === mode);
            btn.setAttribute('aria-selected', btn.dataset.mode === mode);
        });

        if (mode === 'live') {
            // Switch to live
            document.getElementById('replayControls').classList.add('hidden');
            document.getElementById('replayContent').classList.add('hidden');
            document.getElementById('replaySidebar').classList.add('hidden');
            document.getElementById('currentEventBox').classList.add('hidden');
            document.getElementById('liveContent').classList.remove('hidden');
            document.getElementById('liveSidebar').classList.remove('hidden');
            document.getElementById('warningBox').classList.remove('hidden');
            replayData = null;
            replayStep = -1;
            startLivePolling();
        } else {
            // Switch to replay
            stopLivePolling();
            document.getElementById('liveContent').classList.add('hidden');
            document.getElementById('liveSidebar').classList.add('hidden');
            document.getElementById('warningBox').classList.add('hidden');
            document.getElementById('replayControls').classList.remove('hidden');
            document.getElementById('replayContent').classList.remove('hidden');
            document.getElementById('replaySidebar').classList.remove('hidden');

            try {
                replayData = await loadReplayData(mode);
                replayStep = 0;
                document.getElementById('replayRunName').textContent =
                    `Run ${String(replayData.run.number).padStart(2, '0')}: ${replayData.run.name}`;

                // Stats bar
                const s = replayData.stats;
                document.getElementById('replayStats').innerHTML = [
                    `${s.issues_created} issues`,
                    `${s.prs_total} PRs`,
                    `${s.prs_merged} merged`,
                    `+${s.lines_added.toLocaleString()} lines`,
                    `${s.files_changed} files`,
                    replayData.run.tech_stack
                ].map(t => `<span>${escapeHtml(t)}</span>`).join('<span class="text-dim">·</span>');

                renderReplayStep();
            } catch (err) {
                document.getElementById('replayRunName').textContent = 'Error loading run data';
                document.getElementById('replayStats').innerHTML = `<span class="text-red">${escapeHtml(err.message)}</span>`;
            }
        }
    }

    // ── Mode Selector + Run History ──

    function renderModeSelector(runs) {
        const container = document.getElementById('modeSelector');
        runs.forEach(run => {
            const btn = document.createElement('button');
            btn.className = 'mode-btn';
            btn.dataset.mode = run.slug;
            btn.setAttribute('role', 'tab');
            btn.setAttribute('aria-selected', 'false');
            btn.textContent = `${String(run.number).padStart(2, '0')} ${run.name}`;
            btn.onclick = () => switchMode(run.slug);
            container.appendChild(btn);
        });
    }

    function renderRunHistory(runs) {
        const el = document.getElementById('runHistory');
        if (!runs.length) {
            el.innerHTML = '<div class="empty-state">No completed runs found.</div>';
            return;
        }
        const header = `<div class="run-row run-row-header">
            <span>#</span><span>Name</span><span>Tech Stack</span><span>Issues</span><span>PRs</span><span>Date</span>
        </div>`;
        const rows = runs.map(run => `
            <div class="run-row" onclick="switchMode('${escapeHtml(run.slug)}')" title="Replay ${escapeHtml(run.name)}">
                <span class="run-num">${String(run.number).padStart(2, '0')}</span>
                <span style="font-family: var(--sans); font-weight: 700;">${escapeHtml(run.name)}</span>
                <span style="color: var(--color-text-dim); font-size: var(--fs-xs);">${escapeHtml(run.tech_stack)}</span>
                <span style="color: var(--color-text-dim); font-size: var(--fs-sm); font-family: var(--mono);">${run.issues}</span>
                <span style="color: var(--color-text-dim); font-size: var(--fs-sm); font-family: var(--mono);">${run.prs}</span>
                <span style="color: var(--color-text-dim); font-size: var(--fs-xs);">${escapeHtml(run.date)}</span>
            </div>
        `).join('');
        el.innerHTML = header + rows;
    }

    // ── Keyboard Shortcuts ──

    document.addEventListener('keydown', function(e) {
        if (currentMode === 'live') return;
        if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
        if (e.key === 'ArrowRight') { e.preventDefault(); nextStep(); }
        if (e.key === 'ArrowLeft') { e.preventDefault(); prevStep(); }
        if (e.key === 'Home') { e.preventDefault(); resetReplay(); }
        if (e.key === 'Escape') { e.preventDefault(); switchMode('live'); }
    });

    // ── Init ──

    async function init() {
        try {
            const response = await fetch('/api/showcase/runs', { cache: 'no-store' });
            if (response.ok) {
                showcaseRuns = await response.json();
                renderModeSelector(showcaseRuns);
                renderRunHistory(showcaseRuns);
            }
        } catch (e) {
            document.getElementById('runHistory').innerHTML = '<div class="text-dim">Could not load run history.</div>';
        }
        startLivePolling();
    }

    init();
</script>
}
