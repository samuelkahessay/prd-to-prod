@page "/dashboard"
@model DashboardModel
@{
    ViewData["Title"] = "Demo — Ticket Deflection";
    ViewData["NavTitle"] = "DEMO";
}

@section Styles {
<style>
    .term-input {
        width: 100%;
        background: var(--color-bg-base);
        border: 1px solid var(--color-border-heavy);
        color: var(--color-text-primary);
        font-family: var(--mono);
        font-size: var(--fs-sm);
        padding: var(--sp-md);
        outline: none;
        transition: none;
    }
    .term-input:focus { border-color: var(--color-accent); }
    .term-input::placeholder { color: var(--color-text-secondary); text-transform: lowercase; }
    .term-textarea { resize: vertical; min-height: 80px; }
    
    .exec-btn {
        background: var(--color-bg-base);
        border: 1px solid var(--color-border-heavy);
        color: var(--color-text-primary);
        font-family: var(--mono);
        font-size: var(--fs-sm);
        padding: var(--sp-sm) var(--sp-md);
        cursor: pointer;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .exec-btn:hover {
        border-color: var(--color-accent);
        color: var(--color-accent);
        background: var(--color-bg-surface);
    }
    .exec-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .result-line {
        display: grid;
        grid-template-columns: 140px 1fr;
        gap: var(--sp-md);
        padding: var(--sp-xs) 0;
        font-family: var(--mono);
        font-size: var(--fs-sm);
        align-items: baseline;
    }
    .result-key { color: var(--color-text-secondary); text-transform: lowercase; }
    .result-val { color: var(--color-text-primary); }
    .result-val-resolved { color: var(--color-success); }
    .result-val-escalated { color: var(--color-danger); }
    .result-val-accent { color: var(--color-accent); }

    .feed-row {
        display: grid;
        grid-template-columns: 80px 1fr 140px 140px;
        gap: var(--sp-md);
        padding: var(--sp-sm) var(--sp-lg);
        border-bottom: 1px solid var(--color-border);
        align-items: center;
    }
    .feed-row:hover { background: var(--color-bg-surface); }
    .feed-id { color: var(--color-text-secondary); font-family: var(--mono); font-size: var(--fs-xs); }
    .feed-title { color: var(--color-text-primary); font-size: var(--fs-sm); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-family: var(--sans); font-weight: 500;}
    .feed-category { color: var(--color-text-secondary); font-size: var(--fs-xs); font-family: var(--mono); text-transform: lowercase; }
    .feed-status { text-align: right; }
    
    @@media (max-width: 768px) {
        .feed-row {
            grid-template-columns: 80px 1fr 100px;
        }
        .feed-row > :nth-child(3) { display: none; }
        .feed-header {
            grid-template-columns: 80px 1fr 100px !important;
        }
        .feed-header > :nth-child(3) { display: none; }
    }
</style>
}

<div>
    <div style="margin-bottom: var(--sp-2xl);">
        <div class="section-label">// deflection metrics &mdash; system output</div>
        <h1>Ticket Deflection</h1>
        <p class="text-dim" style="max-width: 800px; margin-top: var(--sp-md); font-size: var(--fs-lg);">
            Automated ticket resolution. No human in the loop for matched tickets.
        </p>
    </div>

    <!-- Metrics Bar using .data-grid -->
    <div class="data-grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); margin-bottom: var(--sp-2xl);" aria-label="Key metrics">
        <div class="data-cell">
            <div id="totalTickets" class="metric-val" aria-live="polite">&mdash;</div>
            <div class="metric-lbl">total tickets</div>
        </div>
        <div class="data-cell data-cell-green">
            <div id="resolutionRate" class="metric-val metric-val-green" aria-live="polite">&mdash;</div>
            <div class="metric-lbl text-green">deflection rate</div>
            <div style="color: var(--color-text-secondary); font-size: var(--fs-xs); margin-top: var(--sp-xs); font-family: var(--mono);">% resolved auto</div>
        </div>
        <div class="data-cell data-cell-red">
            <a href="/operator" id="escalated" class="metric-val metric-val-red" style="text-decoration: none;" aria-live="polite">&mdash;</a>
            <div class="metric-lbl text-red">escalated</div>
        </div>
    </div>

    <!-- Submit Panel -->
    <section style="border: 1px solid var(--color-border); margin-bottom: var(--sp-2xl);">
        <div class="section-header">
            <div>
                <div class="section-label">// user input simulation</div>
                <h2>Submit ticket</h2>
            </div>
        </div>
        <div style="padding: var(--sp-lg);">
            <div id="submit-form">
                <div style="margin-bottom: var(--sp-md);">
                    <label class="metric-lbl" for="ticket-title" style="display: block; margin-bottom: var(--sp-xs);">title</label>
                    <input id="ticket-title" class="term-input" type="text" placeholder="e.g. password reset not working" autocomplete="off" />
                </div>
                <div style="margin-bottom: var(--sp-md);">
                    <label class="metric-lbl" for="ticket-desc" style="display: block; margin-bottom: var(--sp-xs);">description (optional)</label>
                    <textarea id="ticket-desc" class="term-input term-textarea" placeholder="Additional context..."></textarea>
                </div>
                <div class="flex-row" style="gap: var(--sp-md);">
                    <button id="submit-btn" class="exec-btn" onclick="submitTicket()">[ submit ]</button>
                    <button id="random-btn" class="exec-btn" onclick="fillRandom()">[ random ]</button>
                    <span id="submit-status" style="font-family: var(--mono); color: var(--color-text-secondary); font-size: var(--fs-xs); text-transform: uppercase;" role="status" aria-live="polite"></span>
                </div>
            </div>
            <div id="submit-result" style="display:none;">
                <div style="border-top: 1px solid var(--color-border); margin-top: var(--sp-md); padding-top: var(--sp-md);">
                    <div id="stage-output" aria-live="polite"></div>
                </div>
                <div id="submit-another" class="flex-row" style="margin-top: var(--sp-lg); display:none;">
                    <button class="exec-btn" onclick="resetForm()">[ submit another ]</button>
                </div>
            </div>
        </div>
    </section>

    <!-- Feed Panel -->
    <section style="border: 1px solid var(--color-border); margin-bottom: var(--sp-2xl);" aria-label="Recent tickets">
        <div class="section-header">
            <div>
                <div class="section-label">// system event log</div>
                <h2>Recent tickets</h2>
            </div>
        </div>
        <div class="feed-header" style="display: grid; grid-template-columns: 80px 1fr 140px 140px; border-bottom: 2px solid var(--color-border-heavy); padding: var(--sp-sm) var(--sp-lg); font-family: var(--mono); font-size: var(--fs-xs); color: var(--color-text-tertiary); text-transform: uppercase; letter-spacing: 0.1em; gap: var(--sp-md);">
            <span>id</span>
            <span>title</span>
            <span>category</span>
            <span style="text-align: right;">status</span>
        </div>
        <div id="feed-body" style="max-height: 480px; overflow-y: auto;" aria-live="polite">
            <div style="padding: var(--sp-lg); color: var(--color-text-secondary); font-family: var(--mono); font-size: var(--fs-sm);">no tickets yet &mdash; submit one to see it here</div>
        </div>
    </section>

</div>

@section Scripts {
<script>
    async function loadFeed() {
        const res = await fetch('/api/metrics/tickets?limit=20&offset=0');
        const tickets = await res.json();
        const body = document.getElementById('feed-body');
        if (!tickets || tickets.length === 0) {
            body.innerHTML = '<div style="padding: var(--sp-lg); color: var(--color-text-secondary); font-family: var(--mono); font-size: var(--fs-sm);">no tickets yet &mdash; submit one to see it here</div>';
            return;
        }
        body.innerHTML = tickets.map(t => {
            const shortId = t.id.substring(0, 8);
            const status = t.status === 'AutoResolved' ? 'AUTO_RESOLVED'
                         : t.status === 'Escalated'   ? 'ESCALATED'
                         : t.status.toUpperCase();
            const tagClass = t.status === 'AutoResolved' ? 'badge badge-green'
                           : t.status === 'Escalated'   ? 'badge badge-red'
                           : 'badge badge-amber';
            const title = t.title.length > 64 ? t.title.substring(0, 63) + '…' : t.title;
            return `<div class="feed-row">
                <span class="feed-id">${shortId}</span>
                <span class="feed-title">${escapeHtml(title)}</span>
                <span class="feed-category">${escapeHtml(t.category)}</span>
                <span class="feed-status"><span class="${tagClass}">${status}</span></span>
            </div>`;
        }).join('');
    }

    async function loadMetrics() {
        const res = await fetch('/api/metrics/overview');
        const data = await res.json();

        document.getElementById('totalTickets').textContent = data.totalTickets;
        document.getElementById('resolutionRate').textContent =
            (data.resolutionRate * 100).toFixed(1) + '%';
        document.getElementById('escalated').textContent = data.escalated;
    }

    loadMetrics();
    loadFeed();

    const STAGE_DELAY_MS = 500;

    function stageDelay(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }

    function appendStageLine(key, value, extraClass) {
        const el = document.createElement('div');
        el.className = 'result-line';
        const keySpan = document.createElement('span');
        keySpan.className = 'result-key';
        keySpan.textContent = key;
        const valSpan = document.createElement('span');
        valSpan.className = 'result-val' + (extraClass ? ' ' + extraClass : '');
        valSpan.textContent = value;
        el.appendChild(keySpan);
        el.appendChild(valSpan);
        document.getElementById('stage-output').appendChild(el);
    }

    function appendStageLineWithSuffix(key, value, valueClass, suffix) {
        const el = document.createElement('div');
        el.className = 'result-line';
        const keySpan = document.createElement('span');
        keySpan.className = 'result-key';
        keySpan.textContent = key;
        const valSpan = document.createElement('span');
        valSpan.className = 'result-val' + (valueClass ? ' ' + valueClass : '');
        valSpan.textContent = value;
        const suffixSpan = document.createElement('span');
        suffixSpan.style.color = 'var(--color-text-secondary)';
        suffixSpan.style.fontFamily = 'var(--mono)';
        suffixSpan.style.fontSize = 'var(--fs-xs)';
        suffixSpan.textContent = suffix;
        el.appendChild(keySpan);
        el.appendChild(valSpan);
        el.appendChild(suffixSpan);
        document.getElementById('stage-output').appendChild(el);
    }

    async function submitTicket() {
        const title = document.getElementById('ticket-title').value.trim();
        if (!title) {
            document.getElementById('submit-status').textContent = 'title is required';
            return;
        }
        const description = document.getElementById('ticket-desc').value.trim();
        const btn = document.getElementById('submit-btn');
        const status = document.getElementById('submit-status');
        btn.disabled = true;
        status.textContent = 'processing...';

        try {
            const res = await fetch('/api/tickets/submit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ title, description, source: 'dashboard' })
            });
            if (!res.ok) throw new Error('HTTP ' + res.status);
            const data = await res.json();

            document.getElementById('submit-form').style.display = 'none';
            document.getElementById('stage-output').innerHTML = '';
            document.getElementById('submit-another').style.display = 'flex';
            document.getElementById('submit-result').style.display = 'block';

            const shortId = data.ticket.id.substring(0, 8);
            const shortTitle = data.ticket.title.length > 50
                ? data.ticket.title.substring(0, 49) + '…'
                : data.ticket.title;
            appendStageLine('intake', 'ticket #' + shortId + ' created — "' + shortTitle + '"', '');
            await stageDelay(STAGE_DELAY_MS);

            appendStageLine('classify',
                data.classification.category + ' · ' + data.classification.severity,
                'result-val-accent');
            await stageDelay(STAGE_DELAY_MS);

            if (data.match && data.match.articleTitle) {
                const score = (data.match.score * 100).toFixed(0);
                appendStageLineWithSuffix('match', data.match.articleTitle, '', ' (score: ' + score + '%)');
            } else {
                appendStageLine('match', 'no matching article', 'text-dim');
            }
            await stageDelay(STAGE_DELAY_MS);

            const isResolved = data.ticket.status === 'AutoResolved';
            if (isResolved) {
                appendStageLine('resolve', 'AUTO_RESOLVED', 'result-val-resolved');
                await stageDelay(STAGE_DELAY_MS);
                if (data.ticket.resolution) {
                    appendStageLine('resolution', data.ticket.resolution, '');
                }
            } else {
                appendStageLine('resolve', 'ESCALATED — no matching article found', 'result-val-escalated');
            }

            await stageDelay(STAGE_DELAY_MS);

            Promise.all([loadFeed(), loadMetrics()]);
        } catch (e) {
            status.textContent = 'error: ' + e.message;
            btn.disabled = false;
        }
    }

    function resetForm() {
        document.getElementById('ticket-title').value = '';
        document.getElementById('ticket-desc').value = '';
        document.getElementById('submit-status').textContent = '';
        document.getElementById('submit-btn').disabled = false;
        document.getElementById('random-btn').disabled = false;
        document.getElementById('submit-result').style.display = 'none';
        document.getElementById('submit-form').style.display = 'block';
    }

    const SAMPLE_TICKETS = [
        { title: 'Error 500 on the server', description: 'I keep getting an error 500 internal server error when loading the main page. The error appears on every request.' },
        { title: 'Application crashes after restart', description: 'The application crashes immediately after restart. I checked the logs but could not find details about the crash recovery steps.' },
        { title: 'How to reset my password', description: 'I forgot my password and clicked the reset link on the login page but the email was never sent to my inbox.' },
        { title: 'How to export my data as CSV', description: 'I need to navigate to settings and export all my data in CSV or JSON format for compliance.' },
        { title: 'How to enable two-factor authentication', description: 'I want to enable 2FA under my security settings using an authenticator app like Google Authenticator or Authy.' },
        { title: 'Submit a feature request via feedback', description: 'How do I submit feature requests through the feedback portal? I want my vote to count in the quarterly review process.' },
        { title: 'Add Slack integration for alerts', description: 'We use Slack for team communication and would love to get ticket alerts directly in our channels.' },
        { title: 'Forgot password and reset email not arriving', description: 'I clicked forgot password on the login page and entered my email but the reset link was never sent to my inbox.' },
        { title: 'Two-factor authentication code not working', description: 'The authenticator app code is not accepted. I enabled 2FA under security settings but it keeps failing.' },
        { title: 'Account locked after failed logins', description: 'My account was locked after multiple failed login attempts. I need a reset link sent to my email.' },
        { title: 'Check service status and uptime', description: 'Where can I check the service status page for real-time information about outages and scheduled maintenance windows?' },
        { title: 'Search returns wrong results', description: 'When I search for recent orders the results show completely unrelated documents from other users.' },
    ];

    let _lastRandomIndex = -1;

    function fillRandom() {
        let idx;
        do { idx = Math.floor(Math.random() * SAMPLE_TICKETS.length); }
        while (idx === _lastRandomIndex && SAMPLE_TICKETS.length > 1);
        _lastRandomIndex = idx;

        const sample = SAMPLE_TICKETS[idx];
        document.getElementById('ticket-title').value = sample.title;
        document.getElementById('ticket-desc').value = sample.description;
        document.getElementById('submit-status').textContent = '';

        document.getElementById('submit-btn').disabled = true;
        document.getElementById('random-btn').disabled = true;
        setTimeout(submitTicket, 300);
    }
</script>
}

