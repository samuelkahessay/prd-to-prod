@page "/"
@model IndexModel
@{
    ViewData["Title"] = "prd-to-prod — autonomous software delivery";
    ViewData["NavTitle"] = "PRD-TO-PROD";
}

@section Head {
    <meta name="description" content="PRD to deployed code. No human in the loop. Autonomous delivery pipeline powered by gh-aw." />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="prd-to-prod" />
    <meta property="og:url" content="https://prd-to-prod.azurewebsites.net" />
    <meta property="og:title" content="prd-to-prod — autonomous software delivery" />
    <meta property="og:description" content="PRD to deployed code. No human in the loop." />
    <meta property="og:image" content="https://prd-to-prod.azurewebsites.net/og-image.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="prd-to-prod — autonomous software delivery" />
    <meta name="twitter:description" content="PRD to deployed code. No human in the loop." />
    <meta name="twitter:image" content="https://prd-to-prod.azurewebsites.net/og-image.png" />
}

@section Styles {
<style>
    /* Hero layout */
    .hero-container {
        padding-top: var(--sp-xk);
        padding-bottom: var(--sp-xl);
    }

    .hero-headline {
        font-size: var(--fs-hero);
        font-family: var(--sans);
        font-weight: 800;
        line-height: 0.85;
        letter-spacing: -0.05em;
        text-transform: uppercase;
        color: var(--color-text-primary);
        max-width: 1100px;
        margin-bottom: var(--sp-2xl);
    }

    .hero-summary {
        font-family: var(--mono);
        font-size: var(--fs-lg);
        color: var(--color-text-secondary);
        line-height: 1.4;
        max-width: 700px;
        margin-bottom: var(--sp-xl);
    }

    .hero-ctas {
        display: flex;
        flex-wrap: wrap;
        gap: var(--sp-md);
        margin-top: var(--sp-2xl);
    }

    /* Utilitarian Pipeline Schematic */
    .pipeline-schematic {
        list-style: none;
        padding: 0;
        margin: 0;
        border: 2px solid var(--color-border-heavy);
        background: var(--color-bg-base);
    }
    
    .pipeline-stage {
        display: grid;
        grid-template-columns: 40px auto 1fr;
        align-items: center;
        gap: var(--sp-md);
        padding: var(--sp-md);
        border-bottom: 1px solid var(--color-border-faint);
        transition: background 0.2s ease-out-expo, color 0.2s ease-out-expo;
    }
    .pipeline-stage:last-child {
        border-bottom: none;
    }
    
    .pipeline-stage:hover {
        background: var(--color-text-primary);
        color: var(--color-bg-base);
    }
    
    .pipeline-stage:hover .pipeline-num,
    .pipeline-stage:hover .pipeline-name,
    .pipeline-stage:hover .pipeline-desc {
        color: var(--color-bg-base);
    }

    .pipeline-num {
        font-family: var(--mono);
        font-weight: 800;
        font-size: var(--fs-xs);
        color: var(--color-text-tertiary);
    }
    .pipeline-name {
        font-family: var(--mono);
        font-weight: 800;
        text-transform: uppercase;
        font-size: var(--fs-sm);
        letter-spacing: 0.1em;
        color: var(--color-text-primary);
    }
    .pipeline-desc {
        font-family: var(--sans);
        font-size: var(--fs-xs);
        color: var(--color-text-secondary);
        text-align: right;
    }

    /* Cursor */
    .cursor-blink::after {
        content: '█';
        color: var(--color-text-primary);
        animation: blink 1s step-end infinite;
        vertical-align: text-bottom;
    }

    @@keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
    }
</style>
}

<div>
    <!-- Hero -->
    <section class="hero-container" aria-labelledby="hero-heading">
        <h1 id="hero-heading" class="hero-headline cursor-blink">
            PRD to deployed<br/>code. AI builds.<br/>Humans decide.
        </h1>
        <p class="hero-summary">
            An autonomous delivery pipeline powered by
            <a href="https://github.com/github/gh-aw" target="_blank" rel="noopener noreferrer">gh-aw</a>.
            Write a product spec as a GitHub issue. AI agents decompose, implement,
            review, and ship it — stopping when a decision requires human judgment.
        </p>
        <div class="hero-ctas">
            <a href="/pipeline" class="btn-primary">View Pipeline &rarr;</a>
            <a href="https://github.com/samuelkahessay/prd-to-prod" target="_blank" rel="noopener noreferrer" class="btn-secondary">GitHub Repository</a>
        </div>
    </section>

    <!-- Evidence strip -->
    <section aria-label="Pipeline statistics" class="data-grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
        <div class="data-cell">
            <div class="evidence-val">@Model.TotalRuns</div>
            <div class="metric-lbl">pipeline runs</div>
        </div>
        <div class="data-cell">
            <div class="metric-val">@Html.Raw(Model.TotalIssues > 0 ? $"{Model.TotalIssues}+" : "0")</div>
            <div class="metric-lbl">issues resolved</div>
        </div>
        <div class="data-cell data-cell-accent">
            <div class="metric-val">@Html.Raw(Model.TotalPrs > 0 ? $"{Model.TotalPrs}+" : "0")</div>
            <div class="metric-lbl">PRs merged</div>
        </div>
        <div class="data-cell">
            <div class="metric-val">~3d</div>
            <div class="metric-lbl">avg PRD-to-PR</div>
        </div>
    </section>
    <div class="divider"></div>

    <!-- Pipeline schematic -->
    <ol class="pipeline-schematic" aria-label="Pipeline stages">
        <li class="pipeline-stage">
            <span class="pipeline-num">01</span>
            <span class="pipeline-name">INPUT</span>
            <span class="pipeline-desc">Human intent + criteria</span>
        </li>
        <li class="pipeline-stage">
            <span class="pipeline-num">02</span>
            <span class="pipeline-name">DECOMPOSE</span>
            <span class="pipeline-desc">Break spec into tasks</span>
        </li>
        <li class="pipeline-stage">
            <span class="pipeline-num">03</span>
            <span class="pipeline-name">IMPLEMENT</span>
            <span class="pipeline-desc">Write code, open PRs</span>
        </li>
        <li class="pipeline-stage">
            <span class="pipeline-num">04</span>
            <span class="pipeline-name">REVIEW</span>
            <span class="pipeline-desc">Check spec and policy</span>
        </li>
        <li class="pipeline-stage">
            <span class="pipeline-num">05</span>
            <span class="pipeline-name">SHIP</span>
            <span class="pipeline-desc">Merge, deploy, escalate</span>
        </li>
    </ol>

    <!-- Integration -->
    <section aria-labelledby="integration-heading" style="margin-top: var(--sp-md);">
        <p id="integration-heading" style="font-family: var(--mono); font-size: var(--fs-xs); color: var(--color-text-tertiary); text-transform: uppercase; letter-spacing: 0.1em;">
            // integration &mdash;
            <span style="color: var(--color-text-secondary);">meeting-to-main</span>:
            meeting transcript in, merged PR out.
            <a href="https://github.com/samuelkahessay/meeting-to-main" target="_blank" rel="noopener noreferrer" style="color: var(--color-accent); text-decoration: underline; text-underline-offset: 3px;">repo &rarr;</a>
        </p>
    </section>

</div>

@section Scripts {
<script>
(function () {
    // Console easter egg
    try {
        console.log('\n%c prd-to-prod', 'color:#e6edf3;font-family:monospace;font-size:20px;font-weight:800');
        console.log('%c Autonomous delivery pipeline. Running in production.\n \u2192 github.com/samuelkahessay/prd-to-prod\n', 'color:#7d8590;font-family:monospace;font-size:12px');
    } catch(e) {}

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    var ease = 'cubic-bezier(0.19, 1, 0.22, 1)'; // Expo out

    var heading    = document.getElementById('hero-heading');
    var subs       = document.querySelectorAll('.hero-summary');
    var ctas       = document.querySelector('.hero-ctas');
    var stages     = document.querySelectorAll('.pipeline-stage');

    function hide(el, tx, ty) {
        if (!el) return;
        el.style.opacity = '0';
        el.style.transform = 'translate(' + (tx || 0) + 'px,' + (ty || 0) + 'px)';
    }

    // Hide elements for entrance
    hide(heading, 0, 20);
    subs.forEach(function(el) { hide(el, 0, 20); });
    hide(ctas, 0, 20);
    stages.forEach(function(el) { hide(el, 20, 0); });

    function animIn(el, delay, dur) {
        if (!el) return;
        dur = dur || 1000; // Even slower, dramatic Brutalist drop-in
        setTimeout(function() {
            el.style.transition = 'opacity ' + dur + 'ms var(--ease-out-expo), transform ' + dur + 'ms var(--ease-out-expo)';
            el.style.opacity = '1';
            el.style.transform = 'translate(0,0)';
            // Do not clear transition so CSS hover works safely, just let it override
        }, delay);
    }

    // Brutalist stagger
    animIn(heading, 100);
    subs.forEach(function(el, i) { animIn(el, 200 + i * 100); });
    animIn(ctas, 300 + subs.length * 100);

    // Stagger pipeline
    var pStart = 400;
    stages.forEach(function(el, i) { 
        animIn(el, pStart + i * 80, 600); 
    });
}());
</script>
}
