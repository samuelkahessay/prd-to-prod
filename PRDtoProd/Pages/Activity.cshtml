@page "/activity"
@model ActivityModel
@{
    ViewData["Title"] = "Activity Log — Ticket Deflection Service";
    ViewData["NavTitle"] = "TICKET DEFLECTION SERVICE";
}

@section Styles {
<style>
    .log-line {
        border-bottom: 1px solid rgba(0, 160, 255, 0.06);
        padding: 10px 0;
        display: grid;
        grid-template-columns: 160px 1fr;
        gap: 16px;
        align-items: start;
    }
    .log-line:last-child { border-bottom: none; }
    @@media (max-width: 480px) {
        .log-line {
            grid-template-columns: 1fr;
            gap: 4px;
        }
    }
    .log-ts {
        color: var(--dim);
        font-size: 0.7rem;
        padding-top: 2px;
        flex-shrink: 0;
    }
    .log-action {
        color: var(--accent);
        font-size: 0.75rem;
        font-weight: 700;
        margin-bottom: 2px;
    }
    .log-details { color: var(--text); font-size: 0.8rem; margin-bottom: 3px; }
    .log-ticket { color: var(--dim); font-size: 0.7rem; }
    .log-ticket span { color: rgba(0, 170, 255, 0.5); }
    .terminal-block {
        background: rgba(4, 10, 20, 0.7);
        border: 1px solid var(--border);
        padding: 1.25rem 1.5rem;
    }
</style>
}

<div class="max-w-4xl mx-auto px-4 py-10">

    <div class="flex items-end justify-between mb-8">
        <div>
            <div class="text-xs text-dim mb-2">// ticket processing trace</div>
            <h1 class="font-sans text-3xl font-bold text-white">Activity Log</h1>
        </div>
        <div class="text-xs text-dim">
            <span id="pageInfo"></span>
        </div>
    </div>

    <div class="terminal-block">
        <div class="text-xs text-dim mb-4">
            <span class="text-accent">$</span> tail -f pipeline.log
        </div>
        <div id="activity-timeline" aria-live="polite" aria-label="Activity log entries">
            <div class="text-dim text-xs py-4">streaming activity log...</div>
        </div>
    </div>

    <div class="flex items-center gap-3 mt-6">
        <button id="prevBtn" onclick="prevPage()"
                class="page-btn" disabled aria-label="Previous page">[ &lt; prev ]</button>
        <button id="nextBtn" onclick="nextPage()"
                class="page-btn" aria-label="Next page">[ next &gt; ]</button>
    </div>
</div>

@section Scripts {
<script>
    const PAGE_SIZE = 20;
    let currentOffset = 0;
    let totalLoaded = 0;

    async function loadActivity() {
        const res = await fetch(`/api/metrics/activity?limit=${PAGE_SIZE}&offset=${currentOffset}`);
        const items = await res.json();
        const container = document.getElementById('activity-timeline');

        if (items.length === 0 && currentOffset === 0) {
            container.innerHTML = '<div class="text-dim text-xs py-4">no activity recorded yet.</div>';
            document.getElementById('pageInfo').textContent = '';
            document.getElementById('nextBtn').disabled = true;
            document.getElementById('prevBtn').disabled = true;
            return;
        }

        container.innerHTML = items.map(item => {
            const ts = new Date(item.timestamp).toISOString().replace('T', ' ').slice(0, 19);
            return `
            <div class="log-line">
                <div class="log-ts">${ts}</div>
                <div>
                    <div class="log-action">&gt; ${escapeHtml(item.action)}</div>
                    <div class="log-details">${escapeHtml(item.details)}</div>
                    <div class="log-ticket">ticket: <span>${escapeHtml(item.ticketId)}</span></div>
                </div>
            </div>`;
        }).join('');

        totalLoaded = items.length;
        const page = Math.floor(currentOffset / PAGE_SIZE) + 1;
        document.getElementById('pageInfo').textContent = `page ${page}`;
        document.getElementById('prevBtn').disabled = currentOffset === 0;
        document.getElementById('nextBtn').disabled = items.length < PAGE_SIZE;
    }

    function prevPage() {
        if (currentOffset >= PAGE_SIZE) {
            currentOffset -= PAGE_SIZE;
            loadActivity();
        }
    }

    function nextPage() {
        if (totalLoaded === PAGE_SIZE) {
            currentOffset += PAGE_SIZE;
            loadActivity();
        }
    }

    loadActivity();
</script>
}
