<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.InMemory" Version="10.0.3" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="10.0.3" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="TicketDeflection.Tests" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="..\showcase\**\*.json" CopyToOutputDirectory="PreserveNewest" Link="showcase\%(RecursiveDir)%(Filename)%(Extension)" />
    <Content Include="..\drills\decisions\**\*.json" CopyToOutputDirectory="PreserveNewest" Link="drills\decisions\%(RecursiveDir)%(Filename)%(Extension)" />
    <Content Include="..\drills\reports\**\*.json" CopyToOutputDirectory="PreserveNewest" Link="drills\reports\%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

</Project>
